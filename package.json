{
  "name": "@bobrossthepainter/pi-comment-ui",
  "version": "0.1.1",
  "type": "module",
  "description": "Pi extension for commenting on the last assistant response with Pi UI, an external editor, or a Glimpse relay window",
  "license": "MIT",
  "author": "Rob Lang <dev@roblang.de>",
  "keywords": [
    "pi-package",
    "pi-extension",
    "comment",
    "glimpse-relay"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bobrossthepainter/pi-comment-ui.git"
  },
  "bugs": {
    "url": "https://github.com/bobrossthepainter/pi-comment-ui/issues"
  },
  "homepage": "https://github.com/bobrossthepainter/pi-comment-ui#readme",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "web",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test test/*.test.mjs",
    "prepack": "npm run check && npm test"
  },
  "dependencies": {
    "@bobrossthepainter/glimpse-relay-client": "^0.2.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@types/node": "^26.0.0",
    "typescript": "^7.0.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
